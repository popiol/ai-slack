# Slack app credentials (Socket Mode)
# Bot token from OAuth & Permissions, needs scopes:
#   channels:history, groups:history (if private channel), chat:write, reactions:write
SLACK_BOT_TOKEN=xoxb-...

# App-level token from Basic Information > App-Level Tokens, needs scope: connections:write
SLACK_APP_TOKEN=xapp-...

# Channel ID to listen on (Channel details > About > Channel ID)
SLACK_CHANNEL_ID=C0123456789

# Comma-separated Slack user IDs allowed to trigger the bot (find via a user's profile > More > Copy member ID)
SLACK_ALLOWED_USERS=U0123456789

# Optional: path to the claude CLI binary (default: "claude", resolved via PATH)
CLAUDE_BIN=claude

# Optional: working directory claude starts in (default: this repo)
CLAUDE_WORKING_DIR=

# Optional: comma-separated extra directories claude may access via --add-dir (default: ~/proj)
CLAUDE_ADD_DIRS=

# Optional: claude --permission-mode (default: bypassPermissions - unattended, no approval prompts)
CLAUDE_PERMISSION_MODE=bypassPermissions

# Optional: max seconds to wait for a single claude run (default: 1800)
CLAUDE_TIMEOUT_SECONDS=1800

# Optional: logging verbosity - INFO (default) or DEBUG for step-by-step message/reaction/session logs
LOG_LEVEL=INFO
